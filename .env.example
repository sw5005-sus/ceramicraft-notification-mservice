# ─── PostgreSQL ────────────────────────────────────────────────────────────
# Shared with other services; in cluster injected via Vault (ms-secret-vault).
POSTGRES_USER=ceramicraft
POSTGRES_PASSWORD=ceramicraft123
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
NOTIFICATION_DB_NAME=notification_db

# ─── HTTP Health-check Server ─────────────────────────────────────────────
NOTIFICATION_MSERVICE_HTTP_HOST=0.0.0.0
NOTIFICATION_MSERVICE_HTTP_PORT=8080

# ─── gRPC Server ──────────────────────────────────────────────────────────
NOTIFICATION_MSERVICE_GRPC_HOST=[::]
NOTIFICATION_MSERVICE_GRPC_PORT=50051

# ─── Firebase Cloud Messaging ─────────────────────────────────────────────
# Can be a file path or a JSON string; in cluster injected via Vault.
FIREBASE_CREDENTIALS_JSON=
